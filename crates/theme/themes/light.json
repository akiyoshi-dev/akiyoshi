{
  "$schema": "./theme.schema.json",
  "id": "akiyoshi_light",
  "name": "Akiyoshi Light",
  "appearance": "light",
  "describe": "基于 shadcn/ui Zinc 配色的浅色主题，黑白简约风格。",
  "author": {
    "name": "Akiyoshi Team",
    "contact": "theme@akiyoshi.local"
  },
  "version": "1.0.0",
  "styles": {
    "colors": {
      "background": "#ffffff",
      "foreground": "#09090b",
      "surface": {
        "default": "#ffffff",
        "hover": "#f4f4f5",
        "active": "#e4e4e7",
        "elevated": "#ffffff"
      },
      "card": {
        "background": "#ffffff",
        "foreground": "#09090b",
        "border": "#e4e4e7"
      },
      "popover": {
        "background": "#ffffff",
        "foreground": "#09090b",
        "border": "#e4e4e7"
      },
      "primary": "#18181b",
      "secondary": "#f4f4f5",
      "accent": "#f4f4f5",
      "muted": "#f4f4f5",
      "danger": "#ef4444",
      "success": "#22c55e",
      "warning": "#f59e0b",
      "info": "#3b82f6",
      "text": {
        "primary": "#09090b",
        "secondary": "#71717a",
        "muted": "#a1a1aa",
        "disabled": "#d4d4d8",
        "inverted": "#fafafa"
      },
      "border": {
        "default": "#e4e4e7",
        "muted": "#f4f4f5",
        "strong": "#d4d4d8"
      },
      "input": {
        "background": "#ffffff",
        "foreground": "#09090b",
        "border": "#e4e4e7",
        "placeholder": "#a1a1aa"
      },
      "ring": "#18181b",
      "overlay": "#09090b"
    },
    "spacing": {
      "xs": 4.0,
      "sm": 8.0,
      "md": 12.0,
      "lg": 16.0,
      "xl": 24.0
    },
    "radius": {
      "sm": 4.0,
      "md": 6.0,
      "lg": 10.0
    },
    "typography": {
      "sm": 14.0,
      "md": 15.0,
      "lg": 18.0
    }
  }
}
