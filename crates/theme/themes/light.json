{
  "$schema": "./theme.schema.json",
  "id": "akiyoshi_light",
  "name": "Akiyoshi Light",
  "appearance": "light",
  "describe": "基于 shadcn/ui 语义令牌的浅色主题，适合白天与高亮环境。",
  "author": {
    "name": "Akiyoshi Team",
    "contact": "theme@akiyoshi.local"
  },
  "version": "1.0.0",
  "styles": {
    "colors": {
      "background": "#ffffff",
      "foreground": "#020817",
      "surface": {
        "default": "#ffffff",
        "hover": "#f8fafc",
        "active": "#f1f5f9",
        "elevated": "#ffffff"
      },
      "card": {
        "background": "#ffffff",
        "foreground": "#020817",
        "border": "#e2e8f0"
      },
      "popover": {
        "background": "#ffffff",
        "foreground": "#020817",
        "border": "#e2e8f0"
      },
      "primary": "#0f172a",
      "secondary": "#f1f5f9",
      "accent": "#f1f5f9",
      "muted": "#f1f5f9",
      "danger": "#ef4444",
      "success": "#22c55e",
      "warning": "#f59e0b",
      "info": "#3b82f6",
      "text": {
        "primary": "#020817",
        "secondary": "#475569",
        "muted": "#64748b",
        "disabled": "#94a3b8",
        "inverted": "#f8fafc"
      },
      "border": {
        "default": "#e2e8f0",
        "muted": "#f1f5f9",
        "strong": "#cbd5e1"
      },
      "input": {
        "background": "#ffffff",
        "foreground": "#020817",
        "border": "#e2e8f0",
        "placeholder": "#94a3b8"
      },
      "ring": "#94a3b8",
      "overlay": "#0f172a"
    },
    "spacing": {
      "xs": 4.0,
      "sm": 8.0,
      "md": 12.0,
      "lg": 16.0,
      "xl": 24.0
    },
    "radius": {
      "sm": 4.0,
      "md": 8.0,
      "lg": 12.0
    },
    "typography": {
      "sm": 12.0,
      "md": 14.0,
      "lg": 16.0
    }
  }
}
