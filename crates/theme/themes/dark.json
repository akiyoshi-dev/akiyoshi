{
  "$schema": "./theme.schema.json",
  "id": "akiyoshi_dark",
  "name": "Akiyoshi Dark",
  "appearance": "dark",
  "describe": "基于 shadcn/ui Zinc 配色的深色主题，黑白简约风格。",
  "author": {
    "name": "Akiyoshi Team",
    "contact": "theme@akiyoshi.local"
  },
  "version": "1.0.0",
  "styles": {
    "colors": {
      "background": "#09090b",
      "foreground": "#fafafa",
      "surface": {
        "default": "#09090b",
        "hover": "#18181b",
        "active": "#27272a",
        "elevated": "#18181b"
      },
      "card": {
        "background": "#09090b",
        "foreground": "#fafafa",
        "border": "#27272a"
      },
      "popover": {
        "background": "#09090b",
        "foreground": "#fafafa",
        "border": "#27272a"
      },
      "primary": "#fafafa",
      "secondary": "#27272a",
      "accent": "#27272a",
      "muted": "#27272a",
      "danger": "#dc2626",
      "success": "#16a34a",
      "warning": "#d97706",
      "info": "#2563eb",
      "text": {
        "primary": "#fafafa",
        "secondary": "#a1a1aa",
        "muted": "#71717a",
        "disabled": "#52525b",
        "inverted": "#18181b"
      },
      "border": {
        "default": "#27272a",
        "muted": "#18181b",
        "strong": "#3f3f46"
      },
      "input": {
        "background": "#09090b",
        "foreground": "#fafafa",
        "border": "#27272a",
        "placeholder": "#71717a"
      },
      "ring": "#d4d4d8",
      "overlay": "#000000"
    },
    "spacing": {
      "xs": 4.0,
      "sm": 8.0,
      "md": 12.0,
      "lg": 16.0,
      "xl": 24.0
    },
    "radius": {
      "sm": 4.0,
      "md": 6.0,
      "lg": 10.0
    },
    "typography": {
      "sm": 14.0,
      "md": 15.0,
      "lg": 18.0,
      "line_height": {
        "sm": 20.0,
        "md": 24.0,
        "lg": 28.0
      }
    }
  }
}
