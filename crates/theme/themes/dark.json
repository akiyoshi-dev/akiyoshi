{
  "$schema": "./theme.schema.json",
  "id": "akiyoshi_dark",
  "name": "Akiyoshi Dark",
  "appearance": "dark",
  "describe": "基于 shadcn/ui 语义令牌的深色主题，适合夜间与低亮环境。",
  "author": {
    "name": "Akiyoshi Team",
    "contact": "theme@akiyoshi.local"
  },
  "version": "1.0.0",
  "styles": {
    "colors": {
      "background": "#020817",
      "foreground": "#f8fafc",
      "surface": {
        "default": "#020817",
        "hover": "#111827",
        "active": "#1f2937",
        "elevated": "#020817"
      },
      "card": {
        "background": "#020817",
        "foreground": "#f8fafc",
        "border": "#1e293b"
      },
      "popover": {
        "background": "#020817",
        "foreground": "#f8fafc",
        "border": "#1e293b"
      },
      "primary": "#f8fafc",
      "secondary": "#1e293b",
      "accent": "#1e293b",
      "muted": "#1e293b",
      "danger": "#7f1d1d",
      "success": "#22c55e",
      "warning": "#f59e0b",
      "info": "#3b82f6",
      "text": {
        "primary": "#f8fafc",
        "secondary": "#94a3b8",
        "muted": "#64748b",
        "disabled": "#64748b",
        "inverted": "#0f172a"
      },
      "border": {
        "default": "#1e293b",
        "muted": "#1f2937",
        "strong": "#334155"
      },
      "input": {
        "background": "#020817",
        "foreground": "#f8fafc",
        "border": "#1e293b",
        "placeholder": "#64748b"
      },
      "ring": "#334155",
      "overlay": "#000000"
    },
    "spacing": {
      "xs": 4.0,
      "sm": 8.0,
      "md": 12.0,
      "lg": 16.0,
      "xl": 24.0
    },
    "radius": {
      "sm": 4.0,
      "md": 8.0,
      "lg": 12.0
    },
    "typography": {
      "sm": 14.0,
      "md": 16.0,
      "lg": 18.0
    }
  }
}
