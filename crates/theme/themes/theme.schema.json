{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akiyoshi.local/theme.schema.json",
  "title": "Akiyoshi Theme (shadcn semantic tokens)",
  "description": "Comprehensive semantic theme schema aligned with shadcn-style token naming.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^\\$schema$": {
      "type": "string",
      "description": "Optional self-reference to this schema file.",
      "examples": ["./theme.schema.json"]
    }
  },
  "required": ["id", "name", "appearance", "styles"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "主题标识符 必须为一"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "主题名称"
    },
    "appearance": {
      "type": "string",
      "enum": ["light", "dark"],
      "description": "主题外观模式"
    },
    "describe": {
      "type": "string",
      "description": "主题描述"
    },
    "author": {
      "$ref": "#/$defs/author",
      "description": "主题作者"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "主题版本，遵循语义化版本规范 (e.g., 1.0.0)"
    },
    "styles": {
      "$ref": "#/$defs/styles"
    }
  },
  "$defs": {
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "contact"],
      "description": "作者对象，包含主题作者的基本信息",
      "properties": {
        "name": {
          "type": "string",
          "description": "主题作者名称"
        },
        "contact": {
          "type": "string",
          "description": "当前主题作者联系方式"
        }
      }
    },
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "styles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["colors", "spacing", "radius", "typography"],
      "properties": {
        "colors": {
          "$ref": "#/$defs/colorTokens",
          "description": "颜色相关的设计令牌配置。"
        },
        "spacing": {
          "$ref": "#/$defs/spacingTokens",
          "description": "间距相关的设计令牌配置。"
        },
        "radius": {
          "$ref": "#/$defs/radiusTokens",
          "description": "边框圆角相关的设计令牌配置。"
        },
        "typography": {
          "$ref": "#/$defs/typographyTokens",
          "description": "排版相关的设计令牌配置。"
        }
      }
    },
    "surfaceTokens": {
      "type": "object",
      "description": "表面层颜色，用于卡片、容器、浮层等。",
      "required": ["default", "hover", "active", "elevated"],
      "additionalProperties": false,
      "properties": {
        "default": {
          "$ref": "#/$defs/hexColor",
          "description": "默认表面背景颜色。"
        },
        "hover": {
          "$ref": "#/$defs/hexColor",
          "description": "鼠标悬停时的表面颜色。"
        },
        "active": {
          "$ref": "#/$defs/hexColor",
          "description": "激活状态下的表面颜色。"
        },
        "elevated": {
          "$ref": "#/$defs/hexColor",
          "description": "提升层级后的表面颜色，例如弹窗。"
        }
      }
    },
    "cardTokens": {
      "type": "object",
      "description": "卡片组件颜色。",
      "additionalProperties": false,
      "required": ["background", "foreground", "border"],
      "properties": {
        "background": {
          "$ref": "#/$defs/hexColor",
          "description": "卡片背景颜色。"
        },
        "foreground": {
          "$ref": "#/$defs/hexColor",
          "description": "卡片文本颜色。"
        },
        "border": {
          "$ref": "#/$defs/hexColor",
          "description": "卡片边框颜色。"
        }
      }
    },
    "popoverTokens": {
      "type": "object",
      "description": "弹出层颜色。",
      "additionalProperties": false,
      "required": ["background", "foreground", "border"],
      "properties": {
        "background": {
          "$ref": "#/$defs/hexColor",
          "description": "弹出层背景颜色。"
        },
        "foreground": {
          "$ref": "#/$defs/hexColor",
          "description": "弹出层文本颜色。"
        },
        "border": {
          "$ref": "#/$defs/hexColor",
          "description": "弹出层边框颜色。"
        }
      }
    },
    "textTokens": {
      "type": "object",
      "additionalProperties": false,
      "description": "文本颜色配置。",
      "required": ["primary", "secondary", "muted", "disabled", "inverted"],
      "properties": {
        "primary": {
          "$ref": "#/$defs/hexColor",
          "description": "主要文本颜色。"
        },
        "secondary": {
          "$ref": "#/$defs/hexColor",
          "description": "次级文本颜色。"
        },
        "muted": {
          "$ref": "#/$defs/hexColor",
          "description": "弱化文本颜色。"
        },
        "disabled": {
          "$ref": "#/$defs/hexColor",
          "description": "禁用状态文本颜色。"
        },
        "inverted": {
          "$ref": "#/$defs/hexColor",
          "description": "反色文本颜色，通常用于深色背景。"
        }
      }
    },
    "borderTokens": {
      "type": "object",
      "description": "边框颜色配置。",
      "additionalProperties": false,
      "required": ["default", "muted", "strong"],
      "properties": {
        "default": {
          "$ref": "#/$defs/hexColor",
          "description": "默认边框颜色。"
        },
        "muted": {
          "$ref": "#/$defs/hexColor",
          "description": "弱化边框颜色。"
        },
        "strong": {
          "$ref": "#/$defs/hexColor",
          "description": "强调边框颜色。"
        }
      }
    },
    "inputTokens": {
      "type": "object",
      "description": "输入组件颜色配置。",
      "additionalProperties": false,
      "required": ["background", "foreground", "border", "placeholder"],
      "properties": {
        "background": {
          "$ref": "#/$defs/hexColor",
          "description": "输入框背景颜色。"
        },
        "foreground": {
          "$ref": "#/$defs/hexColor",
          "description": "输入框文本颜色。"
        },
        "border": {
          "$ref": "#/$defs/hexColor",
          "description": "输入框边框颜色。"
        },
        "placeholder": {
          "$ref": "#/$defs/hexColor",
          "description": "输入框占位符文本颜色。"
        }
      }
    },
    "colorTokens": {
      "type": "object",
      "description": "主题颜色配置。",
      "required": [
        "background",
        "foreground",
        "surface",
        "primary",
        "border",
        "input"
      ],
      "additionalProperties": false,
      "properties": {
        "background": {
          "$ref": "#/$defs/hexColor",
          "description": "应用整体背景颜色。"
        },
        "foreground": {
          "$ref": "#/$defs/hexColor",
          "description": "默认前景色，通常用于默认文本颜色。"
        },
        "surface": {
          "$ref": "#/$defs/surfaceTokens",
          "description": "表面层颜色配置。"
        },
        "card": {
          "$ref": "#/$defs/cardTokens",
          "description": "卡片组件颜色配置。"
        },
        "popover": {
          "$ref": "#/$defs/popoverTokens",
          "description": "弹出层颜色配置。"
        },
        "primary": {
          "$ref": "#/$defs/hexColor",
          "description": "主色调，用于主要按钮、强调操作等。"
        },
        "secondary": {
          "$ref": "#/$defs/hexColor",
          "description": "次要颜色，用于辅助操作。"
        },
        "accent": {
          "$ref": "#/$defs/hexColor",
          "description": "强调颜色，用于高亮、特殊状态等。"
        },
        "muted": {
          "$ref": "#/$defs/hexColor",
          "description": "弱化颜色，用于低强调信息。"
        },
        "danger": {
          "$ref": "#/$defs/hexColor",
          "description": "危险颜色，用于删除、错误操作。"
        },
        "success": {
          "$ref": "#/$defs/hexColor",
          "description": "成功状态颜色。"
        },
        "warning": {
          "$ref": "#/$defs/hexColor",
          "description": "警告状态颜色。"
        },
        "info": {
          "$ref": "#/$defs/hexColor",
          "description": "信息提示颜色。"
        },
        "text": {
          "$ref": "#/$defs/textTokens",
          "description": "文本颜色配置。"
        },
        "border": {
          "$ref": "#/$defs/borderTokens",
          "description": "边框颜色配置。"
        },
        "input": {
          "$ref": "#/$defs/inputTokens",
          "description": "输入组件颜色配置。"
        },
        "ring": {
          "$ref": "#/$defs/hexColor",
          "description": "聚焦状态外圈颜色，例如 focus ring。"
        },
        "overlay": {
          "$ref": "#/$defs/hexColor",
          "description": "遮罩层颜色，例如 Modal 背景遮罩。"
        }
      }
    },
    "spacingTokens": {
      "type": "object",
      "additionalProperties": false,
      "description": "间距相关的设计令牌配置，单位为像素。",
      "required": ["xs", "sm", "md", "lg", "xl"],
      "properties": {
        "xs": {
          "type": "number",
          "minimum": 0
        },
        "sm": {
          "type": "number",
          "minimum": 0
        },
        "md": {
          "type": "number",
          "minimum": 0
        },
        "lg": {
          "type": "number",
          "minimum": 0
        },
        "xl": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "radiusTokens": {
      "type": "object",
      "additionalProperties": false,
      "description": "边框圆角相关的设计令牌配置，单位为像素。",
      "required": ["sm", "md", "lg"],
      "properties": {
        "sm": {
          "type": "number",
          "minimum": 0
        },
        "md": {
          "type": "number",
          "minimum": 0
        },
        "lg": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "typographyTokens": {
      "type": "object",
      "additionalProperties": false,
      "description": "排版相关的设计令牌配置，单位为像素。",
      "required": ["sm", "md", "lg", "line_height"],
      "properties": {
        "sm": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "md": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "lg": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "line_height": {
          "$ref": "#/$defs/lineHeightTokens",
          "description": "各字号对应的默认行高配置。"
        }
      }
    },
    "lineHeightTokens": {
      "type": "object",
      "additionalProperties": false,
      "description": "行高相关的设计令牌配置，单位为像素。",
      "required": ["sm", "md", "lg"],
      "properties": {
        "sm": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "md": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "lg": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
